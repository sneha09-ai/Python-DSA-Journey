class ListNode:
    def __init__(self, val=0, next=None):
        self.val = val
        self.next = next

class Solution:
    def deleteNode(self, node: ListNode) -> None:
        node.val = node.next.val     
        node.next = node.next.next    

head = ListNode(4)
n1 = ListNode(5)
n2 = ListNode(1)
n3 = ListNode(9)
head.next = n1
n1.next = n2
n2.next = n3

Solution().deleteNode(n1)

