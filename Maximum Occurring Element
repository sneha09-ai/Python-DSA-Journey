class Node:
    def __init__(self,val=None,next=None):
        self.val=val
        self.next=next

class SinglyLinkedList:
    def __init__(self):
        self.start=None

    def insert_at_start(self,val):
        new_Node=Node(val)
        if self.start is None:
            self.start=new_Node
        else:
            new_Node.next=self.start
            self.start=new_Node
    def display(self):
        temp=self.start
        while temp:
            print(temp.val,end=" ")
            temp=temp.next     

    def maximum_occurring_element(self):
        if self.start is None:
            return None
        freq={}
        temp=self.start
        while temp:
            if temp.val in freq:
                freq[temp.val]+=1
            else:
                freq[temp.val]=1
            temp=temp.next
            max_occ=max(freq,key=freq.get)
        return max_occ

SLL=SinglyLinkedList()
SLL.insert_at_start(123)         
SLL.insert_at_start(123)                            
SLL.insert_at_start(20)                            
SLL.insert_at_start(250)  
SLL.insert_at_start(123)
SLL.insert_at_start(10)
SLL.display()
print()
print("maximum occurring element:",SLL.maximum_occurring_element())


