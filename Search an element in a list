class Node:
    def __init__(self,data=None,next=None):
        self.data=data
        self.next=next

class SinglyLinkedList:
    def __init__(self):
        self.start=None

    def is_empty(self):
        return self.start is None

    def insert_at_start(self,data):
        new_Node=Node(data,self.start)
        self.start=new_Node

    def print(self):
        if self.is_empty():
            return None
        else:
            temp=self.start
            while temp:
                print(temp.data,end=" ")
                temp=temp.next
            print()

    def search(self,data):   
        if self.is_empty():
            return None
        else:
            temp=self.start
            while temp is not None:
              if temp.data==data:   
                    return temp
              temp=temp.next  
            return None    


SSL=SinglyLinkedList()
SSL.insert_at_start(5)  
SSL.insert_at_start(4)  
SSL.insert_at_start(3)  
SSL.insert_at_start(2)  
SSL.insert_at_start(1)  
SSL.print()

result=SSL.search(4)
if result:
    print(f"element found:{result.data}")
else:
    print("not found")    
