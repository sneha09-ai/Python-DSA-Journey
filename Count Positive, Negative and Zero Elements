class Node:
    def __init__(self,val=None,next=None):
        self.val=val
        self.next=next

class SinglyLinkedList:
    def __init__(self):
        self.start=None

    def insert_at_start(self,val):
        new_Node=Node(val)
        if self.start is None:
            self.start=new_Node
        else:
            new_Node.next=self.start
            self.start=new_Node
    def display(self):
        temp=self.start
        while temp:
            print(temp.val,end=" ")
            temp=temp.next     

    def Count_Positive_Negative_and_Zero_Elements(self):
        if self.start is None:
            return None
        temp=self.start
        positive_count=0
        negative_count=0
        zero_count=0
        while temp:
            if temp.val >0:
                positive_count+=1
            elif temp.val <0:
                negative_count+=1    
            else:
                zero_count+=1
            temp=temp.next   
        return positive_count,negative_count,zero_count

SLL=SinglyLinkedList()
SLL.insert_at_start(-123)         
SLL.insert_at_start(3)                            
SLL.insert_at_start(-20)                            
SLL.insert_at_start(33)  
SLL.insert_at_start(0)
SLL.insert_at_start(0)
SLL.display()
print()
print("Count Positive, Negative and Zero Elements:",SLL.Count_Positive_Negative_and_Zero_Elements())


