class Node:
    def __init__(self,val=None,next=None):
        self.val=val
        self.next=next

class SinglyLinkedList:
    def __init__(self):
        self.start=None

    def insert_at_start(self,val):
        new_Node=Node(val)
        if self.start is None:
            self.start=new_Node
        else:
            new_Node.next=self.start
            self.start=new_Node
    def display(self):
        temp=self.start
        while temp:
            print(temp.val,end=" ")
            temp=temp.next     

    def Count_Prime_Numbers_in_a_Linked_List(self):
        if self.start is None:
            return None
        temp=self.start
        count=0
        while temp:
           n=temp.val
           if n>1:
               prime=True
               for i in range(2,n):
                    if  n % i == 0:
                        prime=False
                        break
               if prime:
                count+=1
           temp=temp.next
        return count 


SLL=SinglyLinkedList()
SLL.insert_at_start(123)         
SLL.insert_at_start(50)                            
SLL.insert_at_start(820)                            
SLL.insert_at_start(900)  
SLL.insert_at_start(3)
SLL.insert_at_start(23)
SLL.display()
print()
print("Count Prime Numbers in a Linked List:",SLL.Count_Prime_Numbers_in_a_Linked_List())


