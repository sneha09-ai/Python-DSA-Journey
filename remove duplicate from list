class Node:
    def __init__(self,val=None,next=None):
        self.val=val
        self.next=next

class SinglyLinkedList:
    def __init__(self):
        self.start=None
        
    def insert_at_start(self,val):
        new_Node=Node(val)
        if self.start is None:
            self.start=new_Node
        else:
            new_Node.next=self.start
            self.start=new_Node

    def display(self):
        temp=self.start
        while temp:
            print(temp.val,end=" ")
            temp=temp.next       

    def remove_duplicate(self):
        if self.start is None:
            return None
        temp=self.start
        while temp:
            temp2=temp
            while temp2.next:
                if temp.val==temp2.next.val:
                    temp2.next=temp2.next.next
                else:    
                 temp2=temp2.next
            temp=temp.next
        return None  

SLL=SinglyLinkedList()
SLL.insert_at_start(50)
