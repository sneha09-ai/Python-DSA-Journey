arr=list(map(int,input("enter the numbers:").split(",")))
largest_number=arr[0]
second_number=arr[0]
third_largest=arr[0]
for i in range(len(arr)):
  if arr[i] > largest_number:
    third_largest=second_number
    second_number=largest_number
    largest_number=arr[i]
  if  arr[i] > second_number and arr[i] != largest_number :
    third_largest=second_number
    second_number=arr[i]
  if  arr[i]  >  third_largest and arr[i] != second_number and arr[i] != largest_number:
    third_largest=arr[i]
print("third largest number:",third_largest)
