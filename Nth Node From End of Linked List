class Node:
    def __init__(self,val=None,next=None):
        self.val=val
        self.next=next

class SinglyLinkedList:
    def __init__(self):
        self.start=None

    def insert_at_start(self,val):
        new_Node=Node(val)
        if self.start is None:
            self.start=new_Node
        else:
            new_Node.next=self.start
            self.start=new_Node
    def display(self):
        temp=self.start
        while temp:
            print(temp.val,end=" ")
            temp=temp.next     

    def n_node(self,n):
        if self.start is None:
            return None
        temp=self.start
        count=0
        while temp:
            count+=1
            temp=temp.next
        pos=n-count
        temp=self.start
        for i in range(pos):
             temp=temp.next
        return temp.val    

SLL=SinglyLinkedList()
SLL.insert_at_start(50)         
