class Node:
    def __init__(self,val=None,next=None):
        self.val=val
        self.next=next

class SinglyLinkedList:
    def __init__(self):
        self.start=None

    def insert_at_start(self,val):
        new_Node=Node(val)
        if self.start is None:
            self.start=new_Node
        else:
            new_Node.next=self.start
            self.start=new_Node
    def display(self):
        temp=self.start
        while temp:
            print(temp.val,end=" ")
            temp=temp.next     

    def Count_Nodes_less_Than_X(self,val):
        if self.start is None:
            return None
        temp=self.start
        count=0
        while temp:
            if temp.val<val:
                count+=1
            temp=temp.next
        return count        
        

SLL=SinglyLinkedList()
SLL.insert_at_start(123)         
SLL.insert_at_start(3)                            
SLL.insert_at_start(820)                            
SLL.insert_at_start(900)  
SLL.insert_at_start(30)
SLL.insert_at_start(23)
SLL.display()
print()
print("Count Nodes less Than X:",SLL.Count_Nodes_less_Than_X(900))


