arr=list(map(int,input("enter the number:").split(",")))
arr.sort()
min_diff=arr[1]-arr[0]
for i in range(len(arr)-1):
    diff=arr[i+1]-arr[i]
    if diff<min_diff:
        min_diff=diff
result=[]
for i in range(len(arr)-1):
    diff=arr[i+1]-arr[i]
    if diff==min_diff:
        result.append([arr[i],arr[i+1]])
print("minimum difference pairs:",result)        
