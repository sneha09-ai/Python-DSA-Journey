class Node:
    def __init__(self,val=None,next=None):
        self.val=val
        self.next=next

class SinglyLinkedList:
    def __init__(self):
        self.start=None

    def insert_at_start(self,val):
        new_Node=Node(val)
        if self.start is None:
            self.start=new_Node
        else:
            new_Node.next=self.start
            self.start=new_Node
    def display(self):
        temp=self.start
        while temp:
            print(temp.val,end=" ")
            temp=temp.next     

    def Position_of_Maximum_Element(self):
        if self.start is None:
            return None
        temp=self.start
        max_val=self.start.val
        max_pos=1
        position=1
        while temp:
            if temp.val>max_val:
                max_val=temp.val
                max_pos=position
            position+=1
            temp=temp.next
        return max_pos    

SLL=SinglyLinkedList()
SLL.insert_at_start(123)         
SLL.insert_at_start(30)                            
SLL.insert_at_start(820)                            
SLL.insert_at_start(900)  
SLL.insert_at_start(30)
SLL.insert_at_start(23)
SLL.display()
print()
print("the Position of Maximum Element:",SLL.Position_of_Maximum_Element())


