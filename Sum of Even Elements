class Node:
    def __init__(self,val=None,next=None):
        self.val=val
        self.next=next

class SinglyLinkedList:
    def __init__(self):
        self.start=None

    def insert_at_start(self,val):
        new_Node=Node(val)
        if self.start is None:
            self.start=new_Node
        else:
            new_Node.next=self.start
            self.start=new_Node
    def display(self):
        temp=self.start
        while temp:
            print(temp.val,end=" ")
            temp=temp.next     

    def Sum_of_Even_Elements(self):
        if self.start is None:
            return None
        temp=self.start
        even_total=0
        while temp:
            if temp.val % 2 == 0:
                even_total+=temp.val
            temp=temp.next
        return even_total        
        

SLL=SinglyLinkedList()
SLL.insert_at_start(123)         
SLL.insert_at_start(3)                            
SLL.insert_at_start(820)                            
SLL.insert_at_start(900)  
SLL.insert_at_start(30)
SLL.insert_at_start(23)
SLL.display()
print()
print("Sum of Even Elements:",SLL.Sum_of_Even_Elements())


