arr=list(map(int,input("enter only 0 and 1:").split(",")))
max_length=0
for i in range(len(arr)):
    zero=0
    one=0
    for j in range(i,len(arr)):
        if arr[j]==0:
            zero+=1
        else:
            one+=1
        if zero==one:
            max_length=max(max_length,j-i+1)
print("maximum length:",max_length) 
